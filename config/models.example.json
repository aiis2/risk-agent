{
  "_comment": "多模型 Provider 配置示例，复制为 risk_agent_data/config/models.json 后编辑",
  "defaultProvider": "openai",
  "defaultModel": "gpt-4o",
  "providers": [
    {
      "id": "openai-gpt4o",
      "provider": "openai",
      "model": "gpt-4o",
      "displayName": "GPT-4o（推荐）",
      "apiKeyEnv": "OPENAI_API_KEY",
      "maxTokens": 128000,
      "temperature": 0.2,
      "enabled": true,
      "priority": 1,
      "_comment": "主力模型，综合能力最强"
    },
    {
      "id": "openai-gpt4o-mini",
      "provider": "openai",
      "model": "gpt-4o-mini",
      "displayName": "GPT-4o Mini",
      "apiKeyEnv": "OPENAI_API_KEY",
      "maxTokens": 128000,
      "temperature": 0.2,
      "enabled": false,
      "priority": 2,
      "_comment": "低成本快速响应，适合辅助任务"
    },
    {
      "id": "anthropic-claude-sonnet",
      "provider": "anthropic",
      "model": "claude-sonnet-4-5",
      "displayName": "Claude Sonnet 4.5",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "maxTokens": 200000,
      "temperature": 0.2,
      "enabled": false,
      "priority": 3,
      "_comment": "超大上下文窗口，适合长文档分析"
    },
    {
      "id": "dashscope-qwen3-coder-plus",
      "provider": "openai-compatible",
      "model": "qwen3-coder-plus",
      "displayName": "DashScope Qwen3 Coder Plus（OpenAI Compatible）",
      "baseUrl": "https://coding.dashscope.aliyuncs.com/v1",
      "apiKeyEnv": "DASHSCOPE_API_KEY",
      "toolProtocol": "openai-tools",
      "maxTokens": 32000,
      "temperature": 0.2,
      "enabled": false,
      "priority": 4,
      "_comment": "已验证可用于兼容 OpenAI tools + SSE 的 DashScope 示例，真实 API Key 仅放环境变量"
    },
    {
      "id": "anthropic-compatible-gateway",
      "provider": "anthropic-compatible",
      "model": "claude-compatible-model",
      "displayName": "Anthropic Compatible Gateway",
      "baseUrl": "https://your-anthropic-compatible-endpoint.example.com",
      "apiKeyEnv": "ANTHROPIC_COMPATIBLE_API_KEY",
      "toolProtocol": "anthropic-messages",
      "maxTokens": 64000,
      "temperature": 0.2,
      "enabled": false,
      "priority": 5,
      "_comment": "兼容 Anthropic Messages/tool_use 的第三方网关示例"
    },
    {
      "id": "ollama-llama3",
      "provider": "ollama",
      "model": "llama3.1:8b",
      "displayName": "Llama 3.1 8B（本地）",
      "baseUrl": "http://localhost:11434",
      "maxTokens": 8192,
      "temperature": 0.3,
      "enabled": false,
      "priority": 10,
      "_comment": "本地 Ollama 模型，离线可用，适合测试"
    }
  ]
}
