{
  "name": "@risk-agent/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "predev": "pnpm --filter @risk-agent/core build",
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo",
    "cli:terminal": "tsx src/cli/terminal.ts",
    "db:reset": "tsx src/cli/db.ts reset",
    "db:export": "tsx src/cli/db.ts export",
    "db:import": "tsx src/cli/db.ts import"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/websocket": "^11.3.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@playwright/mcp": "^0.0.71",
    "@risk-agent/core": "workspace:*",
    "cron-parser": "^5.5.0",
    "fastify": "^5.10.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^24.13.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
