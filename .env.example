# ── LLM 配置 ────────────────────────────────────────────────
# LLM 模型配置通过 Web UI「设置 → 模型」完成，以下 Key 用于后端直接调用时的回退
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OLLAMA_BASE_URL=http://localhost:11434

# ── 服务器配置 ───────────────────────────────────────────────
RISK_AGENT_PORT=8787
RISK_AGENT_HOST=127.0.0.1
# 开发数据目录（默认 ./risk_agent_data）
RISK_AGENT_DATA_DIR=

# ── 存储 Profile（可选）─────────────────────────────────────
# 覆盖 /health 端点上报的 storageProfile 名称
# RISK_AGENT_STORAGE_PROFILE=embedded
# 覆盖存储配置文件路径（默认 <DATA_DIR>/config/storage.json）
# STORAGE_CONFIG_PATH=

# ── 日志 ─────────────────────────────────────────────────────
LOG_LEVEL=info

# ── 运行时环境 ───────────────────────────────────────────────
NODE_ENV=development
